# Backend API base URL used by the React app.
# Local: http://localhost:5000/api
# Production: https://your-backend-url.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# Backward-compatible alias used by older local setups.
VITE_API_URL=http://localhost:5000/api

# Socket.io backend URL for booking chat.
VITE_SOCKET_URL=http://localhost:5000

# GitHub Pages repository base path. Example: /gotrippy/
VITE_BASE_PATH=/

# Public business contact details displayed in the frontend.
VITE_BUSINESS_PHONE=8885863662
VITE_WHATSAPP_NUMBER=918885863662
